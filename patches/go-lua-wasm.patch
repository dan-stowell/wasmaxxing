diff --git a/clock_wasm.go b/clock_wasm.go
new file mode 100644
index 0000000..01ea87b
--- /dev/null
+++ b/clock_wasm.go
@@ -0,0 +1,15 @@
+//go:build wasip1 || js
+// +build wasip1 js
+
+package lua
+
+import "time"
+
+// processStart anchors a wall-clock approximation of os.clock() on WebAssembly
+// targets, where syscall.Getrusage (CPU time) is unavailable.
+var processStart = time.Now()
+
+func clock(l *State) int {
+	l.PushNumber(time.Since(processStart).Seconds())
+	return 1
+}
